{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "rootDir": ".",
    "strict": false,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "types": [
      "compression",
      "express-session",
      "mocha",
      "sinon",
      "mocha"
    ]
  },
  "include": [
    "lib",
    "run",
    "test"
  ],
  "exclude": [
    "node_modules"
  ]
}
